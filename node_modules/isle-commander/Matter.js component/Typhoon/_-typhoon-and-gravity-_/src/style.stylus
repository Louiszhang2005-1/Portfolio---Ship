// INIT
mainColor = #32234A;
secondaryColor = #D90368;
bgColor = #8789C0;

body, html
  width: 100%;
  height: 100%;
  overflow: hidden
  // background-color: bgColo
  background-image: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);  
  margin: 0
  font-family: Century Gothic,CenturyGothic,AppleGothic,sans-serif

.f
  position: fixed
  bottom: 5px
  right: 15px
  font-family: 'Arial'
  font-size: 0.7rem
  color: mainColor
  text-align: center;

  a
    font-size: 0.8rem
    color: secondaryColor

// fix dat gui bug
.slider {
  width: 56% !important;
}
